APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------
# Odoo ERP Configuration
# -----------------------------------------------
ODOO_URL=https://mycompany.odoo.com
ODOO_DB=mycompany
ODOO_USERNAME=api@mycompany.com
ODOO_API_KEY=
ODOO_TIMEOUT=30
# JSON map of Odoo location IDs to Shopify location IDs
# e.g. {"1": "65432100001"}
ODOO_LOCATION_SHOPIFY_LOCATION_MAP={}

# -----------------------------------------------
# Shopify Configuration
# -----------------------------------------------
SHOPIFY_SHOP=mystore
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_SECRET=
# Full public URL prefix for webhook callbacks (no trailing slash)
SHOPIFY_WEBHOOK_CALLBACK_URL=https://myapp.example.com/api/webhooks/shopify
# Set to true only if you want Shopify inventory updates to write back to Odoo
# (Odoo is the default source of truth for inventory)
SHOPIFY_INVENTORY_WRITEBACK=false

# -----------------------------------------------
# Amazon SP-API Configuration
# -----------------------------------------------
# Create an app at: https://sellercentral.amazon.com/apps/authorize/consent
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
# Generate via: Seller Central → Apps & Services → Manage Your Apps → Authorise → get refresh token
AMAZON_LWA_REFRESH_TOKEN=

AMAZON_SELLER_ID=
# Marketplace IDs: US=ATVPDKIKX0DER, UK=A1F83G8C2ARO7P, DE=A1PA6795UKMFR9, FR=A13V1IB3VIYZZH, CA=A2EUQ1WTGCTBG2
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Regional SP-API endpoint (NA / EU / FE)
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# FBM = you fulfill, FBA = Amazon fulfills (FBA skips inventory push)
AMAZON_FULFILLMENT_CHANNEL=FBM

# How often (seconds) to re-check feed status (default 5 min)
AMAZON_FEED_POLL_SECONDS=300

# Default product condition for new listings
AMAZON_PRODUCT_CONDITION=new_new

AMAZON_TIMEOUT=30
